# Public Supabase config. These values are safe to expose to the browser.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only Supabase service role key. Never expose this in client code.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Required only if src/lib/auth.ts legacy iron-session helpers are used.
# Must be at least 32 characters.
SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Comma-separated allowed browser origins for POST server functions.
# Include your production domain(s). Localhost defaults are already allowed in code.
ALLOWED_ORIGINS=https://cityqlo.com,https://www.cityqlo.com

# Optional: POST server error payloads to a monitoring webhook.
# Example targets: Sentry/Better Stack/Logtail custom HTTP intake, Slack workflow webhook, or your own endpoint.
ERROR_WEBHOOK_URL=
